{
  "rules": {
    "state": {
      ".read": true,
      ".write": true
    },
    "scores": {
      "$round": {
        ".read": true,
        ".write": "!data.exists() || !newData.exists()",
        "$id": {
          ".write": "!data.exists() || !newData.exists()",
          ".validate": "newData.hasChildren(['name','cost','timeSec']) && newData.child('name').isString() && newData.child('name').val().length <= 18 && newData.child('cost').isNumber() && newData.child('cost').val() > 0 && newData.child('timeSec').isNumber()"
        }
      }
    }
  }
}
